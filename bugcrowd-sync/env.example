# Copy to .env and fill credentials.
# Required auth: either BUGCROWD_AUTHHEADER or BUGCROWD_USERNAME + BUGCROWD_PASSWORD.

BUGCROWD_USERNAME=
BUGCROWD_PASSWORD=

# Optional token auth value (if set, this takes precedence over username/password):
# BUGCROWD_AUTHHEADER=Token your_bugcrowd_username:your_bugcrowd_api_token

# Optional API endpoint override.
BUGCROWD_BASE_URL=https://api.bugcrowd.com

# Set to true only for local SSL debugging with broken cert chains.
BUGCROWD_SSL_UNVERIFIED=false
