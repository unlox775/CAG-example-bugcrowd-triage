# Triage Bot Environment Variables
# Copy this file to triage_bot/.env and edit values for your environment.

# Root workspace where investigation folders are created.
# For this standalone example, the repository root is a sensible default.
PENTEST_ROOT=..

# Report location and schema mapping (pluggable report format support)
BLOCKER_REPORT_DIR=../secretary/blocked_report
BLOCKER_REPORT_FILENAME_TEMPLATE={date}_blocker_report.json
REPORT_ANALYZE_KEY=analyze_pen_test
REPORT_SHORT_ID_KEY=short_id
REPORT_TITLE_KEY=title
REPORT_PRIORITY_KEY=urgency
REPORT_RUNTIMES_KEY=agent_runtimes
REPORT_PENTEST_FOLDER_KEY=pentest_folder
REPORT_PEN_TEST_CREATED_KEY=pen_test_already_created

# Validation behavior
MAX_VALIDATION_RETRIES=3
# Optional custom command, supports placeholders:
# {pentest_folder}, {folder}, {triage_bot_dir}
# VALIDATOR_CMD=python triage_bot/validate_pentest.py {pentest_folder}

# Optional analysis repos used for read-only context in Codex runs.
# Format: name|branch|/abs/path;name2|main|/abs/path2
# Branch is optional: name|/abs/path
ANALYSIS_REPOS=

# Legacy repo env vars remain supported for backward compatibility:
# REPO_CODE_DOT_ORG=/abs/path/to/repo
# REPO_MARKETING_SITES=/abs/path/to/repo
# REPO_INFRASTRUCTURE=/abs/path/to/repo
# REPO_JAVABUILDER=/abs/path/to/repo
# REPO_AIPROXY=/abs/path/to/repo
